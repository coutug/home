{
	"$schema": "https://opencode.ai/config.json",
	"theme": "github",
	"autoupdate": false,
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"read": "allow",
		"grep": "allow",
		"glob": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"webfetch": "allow",
		"question": "allow"
	},
	"default_agent": "plan",
	"agent": {
		"plan": {
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/plan.md}"
		},
		"build": {
			"model": "openai/gpt-5.5-fast",
			"prompt": "{file:./prompts/build.md}"
		},
		"dashboard-builder": {
			"description": "Orchestrates Grafana dashboard creation and iterative test publishing",
			"mode": "primary",
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/dashboard-builder.md}",
			"steps": 20,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "allow",
				"edit": "ask",
				"bash": "ask",
				"task": "deny",
				"skill": {
					"*": "deny",
					"build-dashboard": "allow"
				}
			}
		},
		"teacher": {
			"description": "Teaches hard concepts and code",
			"mode": "primary",
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/teacher.md}",
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		}
	},
	"mcp": {
		"incidentio": {
			"type": "remote",
			"url": "https://mcp.incident.io/mcp",
			"enabled": false
		},
		"victoriametrics-pinax": {
			"type": "remote",
			"url": "https://victoria-metrics-mcp.ott-monitor1.pinax.io/mcp",
			"enabled": false
		},
		"quickwit-pinax": {
			"type": "remote",
			"url": "https://quickwit-mcp.ott-monitor1.pinax.io/mcp",
			"enabled": false
		},
		"grafana-pinax": {
			"type": "remote",
			"url": "https://grafana-mcp.ott-monitor1.pinax.io/mcp",
			"enabled": false
		},
		"kubernetes": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"kubernetes-mcp-server@latest",
				"--read-only"
			],
			"enabled": false
		},
		"github": {
			"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "ENC[AES256_GCM,data:GdDVeMcjtm2t9TfRCxzuWNooYtENr/AjOCyvwgKYPvfZIGasDydNYqymZYOq75Z39SdiryoHAA//C5PYK/PieQLU8SXGHi8LYet12W0hwTEL5a4Kv75Wvhr57I6/UXSzcrgvMg==,iv:f/Zr9NUQL/r+aIMyfMbVXCm9KgYNeXWrMparWsUwTfI=,tag:EpUcfKwyGmRVOeh/qTC7cw==,type:str]"
			},
