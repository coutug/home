{
	"$schema": "https://opencode.ai/config.json",
	"theme": "github",
	"autoupdate": false,
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"read": "allow",
		"grep": "allow",
		"glob": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"webfetch": "allow",
		"question": "allow"
	},
	"default_agent": "plan",
	"agent": {
		"plan": {
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/plan.md}"
		},
		"build": {
			"model": "openai/gpt-5.5-fast",
			"prompt": "{file:./prompts/build.md}"
		},
		"dashboard-builder": {
			"description": "Orchestrates Grafana dashboard creation and iterative test publishing",
			"mode": "primary",
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/dashboard-builder/orchestrator.md}",
			"steps": 20,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "allow",
				"edit": "ask",
				"bash": "ask",
				"task": {
					"*": "deny",
					"dashboard-*": "allow",
					"vm-metrics-analyst": "allow"
				}
			}
		},
		"teacher": {
			"description": "Teaches hard concepts and code",
			"mode": "primary",
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/teacher.md}",
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		},
		"dashboard-researcher": {
			"description": "Researches dashboard and monitoring best practices for the target application",
			"mode": "subagent",
			"hidden": true,
			"model": "openai/gpt-5.5-fast",
			"prompt": "{file:./prompts/dashboard-builder/researcher.md}",
			"steps": 6,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		},
		"vm-metrics-analyst": {
			"description": "Analyzes VictoriaMetrics data to find useful metrics for the dashboard",
			"mode": "subagent",
			"hidden": true,
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/dashboard-builder/metrics-analyst.md}",
			"steps": 8,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		},
		"dashboard-architect": {
			"description": "Designs the high-level dashboard structure, variables, and section layout",
			"mode": "subagent",
			"hidden": true,
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/dashboard-builder/architect.md}",
			"steps": 6,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		},
		"panel-designer": {
			"description": "Designs each Grafana panel in detail",
			"mode": "subagent",
			"hidden": true,
			"model": "openai/gpt-5.5-fast",
			"prompt": "{file:./prompts/dashboard-builder/panel-designer.md}",
			"steps": 8,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "deny",
				"edit": "deny",
				"bash": "deny",
				"task": "deny"
			}
		},
		"dashboard-implementer": {
			"description": "Builds and iterates on the Grafana dashboard test version and final JSON",
			"mode": "subagent",
			"hidden": true,
			"model": "openai/gpt-5.5",
			"prompt": "{file:./prompts/dashboard-builder/implementer.md}",
			"steps": 12,
			"permission": {
				"read": "allow",
				"glob": "allow",
				"grep": "allow",
				"question": "allow",
				"webfetch": "allow",
				"todowrite": "allow",
				"edit": "allow",
				"bash": "allow",
				"task": "deny"
			}
		}
	},
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "ollama (local)",
			"options": {
				"baseURL": "http://192.168.0.56:11434/v1",
				"num_ctx": "32k"
			},
			"models": {
				"qwen3-coder:30b": {
					"name": "qwen3-coder"
				},
				"devstral-small-2:latest": {
					"name": "devstral-small-2"
				}
			}
		}
	},
	"mcp": {
		"incidentio-remote": {
			"type": "remote",
			"url": "https://mcp.incident.io/mcp",
			"enabled": false
		},
		"victoriametrics": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"VM_INSTANCE_ENTRYPOINT",
				"-e",
				"VM_INSTANCE_TYPE",
				"-e",
				"MCP_SERVER_MODE",
				"ghcr.io/victoriametrics-community/mcp-victoriametrics"
			],
			"environment": {
				"VM_INSTANCE_ENTRYPOINT": "https://vmselect.ott-monitor1.pinax.io",
				"VM_INSTANCE_TYPE": "cluster",
				"MCP_SERVER_MODE": "stdio"
			},
			"enabled": false
		},
		"grafana-pinax": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"GRAFANA_URL",
				"-e",
				"GRAFANA_SERVICE_ACCOUNT_TOKEN",
				"mcp/grafana",
				"-t",
				"stdio"
			],
			"environment": {
				"GRAFANA_URL": "https://ops.stats.pinax.network/",
				"GRAFANA_SERVICE_ACCOUNT_TOKEN": "ENC[AES256_GCM,data:OeypT7cyhzRbbeNA+5tdWt9+oMVYXau8D1v2CAit8DVsTjoipaTx7WSc5MdHqw==,iv:LHkvd3lWvDFiHFuh3D5B0Gq77zSyuz6zZZr3E1GMOOQ=,tag:pkof812OQFdtZBVhIBJgpA==,type:str]"
			},
			"enabled": false
		},
		"kubernetes": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"kubernetes-mcp-server@latest",
				"--read-only"
			],
			"enabled": false
		}
	},
