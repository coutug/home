{
	"$schema": "https://opencode.ai/config.json",
	"theme": "github",
	"autoupdate": false,
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"read": "allow",
		"grep": "allow",
		"glob": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"webfetch": "allow",
		"question": "allow"
	},
	"default_agent": "plan",
	"agent": {
		"plan": {
			"model": "openai/gpt-5.4",
			"prompt": "{file:./prompts/plan.md}"
		},
		"build": {
			"model": "openai/gpt-5.4-mini",
			"prompt": "{file:./prompts/build.md}"
		},
		"dashboard-builder": {
			"model": "openai/gpt-5.4",
			"prompt": "{file:./prompts/test-dash.md}"
		}
	},
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "ollama (local)",
			"options": {
				"baseURL": "http://192.168.0.56:11434/v1",
				"num_ctx": "32k"
			},
			"models": {
				"qwen3-coder:30b": {
					"name": "qwen3-coder"
				},
				"devstral-small-2:latest": {
					"name": "devstral-small-2"
				}
			}
		}
	},
	"mcp": {
		"incidentio": {
			"type": "local",
			"command": [
				"/home/gabriel/sync/Travail/Repo/incidentio-mcp-golang/start-mcp-server.sh"
			],
			"environment": {
				"INCIDENT_IO_API_KEY": "ENC[AES256_GCM,data:mI6yFd+dYQQiuFYnf28rB4G6OCvKwGnRNtFpQWOcCdjZYPgZJkEKc4Sosm6ibdt1d9rKU5Kt0oXrHnVZNRotRESWxKk=,iv:I7boTZxxE/L706gw55HFHZYN15HRY39II+Rq43oLky8=,tag:laj+qBUbnf0QpZGAnPPing==,type:str]"
			},
			"enabled": false
		},
		"victoriametrics": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"VM_INSTANCE_ENTRYPOINT",
				"-e",
				"VM_INSTANCE_TYPE",
				"-e",
				"MCP_SERVER_MODE",
				"ghcr.io/victoriametrics-community/mcp-victoriametrics"
			],
			"environment": {
				"VM_INSTANCE_ENTRYPOINT": "https://vmselect.ott-monitor1.pinax.io",
				"VM_INSTANCE_TYPE": "cluster",
				"MCP_SERVER_MODE": "stdio"
			},
			"enabled": false
		},
		"grafana": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"GRAFANA_URL",
				"-e",
				"GRAFANA_SERVICE_ACCOUNT_TOKEN",
				"mcp/grafana",
				"-t",
				"stdio"
			],
			"environment": {
				"GRAFANA_URL": "https://ops.stats.pinax.network/",
				"GRAFANA_SERVICE_ACCOUNT_TOKEN": "ENC[AES256_GCM,data:68uZI6i9lBEngwtqkBPup1KLSu7zdhCCSs+d8+CDd1xdJtfOr5aSGQ7cYP/F9Q==,iv:b+FaeJdCBOqjCmJYVJE1P3ONKj5eMdorQaFvIeRCe0s=,tag:sLhch5cs8W4UYkW8HYIvQA==,type:str]"
			},
			"enabled": false
		},
		"docker": {
			"type": "local",
			"command": [
				"uvx",
				"docker-mcp"
			],
			"enabled": false
		},
		"kubernetes": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"kubernetes-mcp-server@latest",
				"--read-only"
			],
			"enabled": false
		},
		"github": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--pull=always",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN",
				"ghcr.io/github/github-mcp-server"
			],
			"environment": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
			},
			"enabled": false
		}
	},
