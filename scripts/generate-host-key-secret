#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'usage: %s <hostname>\n' "${0##*/}" >&2
}

if [[ $# -ne 1 ]]; then
  usage
  exit 1
fi

host="$1"

repo_root="$(git rev-parse --show-toplevel)"
secret_dir="$repo_root/secrets/hosts/$host"
secret_file="$secret_dir/ssh_host_ed25519_key.yaml"

if [[ -e "$secret_file" ]]; then
  printf 'ERROR: secret already exists: %s\n' "$secret_file" >&2
  exit 1
fi

mkdir -p "$secret_dir"

old_umask="$(umask)"
umask 077
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

ssh-keygen \
  -t ed25519 \
  -N "" \
  -C "$host host key" \
  -f "$tmpdir/ssh_host_ed25519_key" \
  >/dev/null

recipient="$(ssh-to-age -i "$tmpdir/ssh_host_ed25519_key.pub")"

{
  printf 'ssh_host_ed25519_key: |\n'
  sed 's/^/  /' "$tmpdir/ssh_host_ed25519_key"
  printf 'ssh_host_ed25519_key_pub: "%s"\n' "$(cat "$tmpdir/ssh_host_ed25519_key.pub")"
  printf 'age_recipient: "%s"\n' "$recipient"
} >"$tmpdir/secret.yaml"

sops --encrypt "$tmpdir/secret.yaml" >"$secret_file"
umask "$old_umask"

printf 'Created: %s\n\n' "$secret_file"
printf 'Age recipient for %s:\n%s\n\n' "$host" "$recipient"
printf 'Add this recipient to the relevant SOPS creation rules before encrypting host secrets.\n'
